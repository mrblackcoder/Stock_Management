# =============================================================================
# Stock Management System - Docker Environment Variables
# Copy this file to .env and customize for your environment
# =============================================================================

# -----------------------------------------------------------------------------
# MySQL Configuration
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=change_me_root_password
MYSQL_DATABASE=inventory_management_db
MYSQL_USER=inventory_user
MYSQL_PASSWORD=change_me_database_password

# -----------------------------------------------------------------------------
# Backend Configuration
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=docker

# JWT Configuration (CHANGE IN PRODUCTION!)
# Generate a secure value, e.g. `openssl rand -hex 32`
JWT_SECRET=change_me_with_a_long_random_secret
JWT_EXPIRATION=900000

# Admin Configuration (CHANGE IN PRODUCTION!)
ADMIN_PASSWORD=change_me_admin_password

# CORS Configuration
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:80,http://frontend:80

# -----------------------------------------------------------------------------
# Frontend Configuration
# -----------------------------------------------------------------------------
REACT_APP_API_URL=http://localhost:8080/api
REACT_APP_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# Production Overrides (uncomment for production)
# -----------------------------------------------------------------------------
# SPRING_PROFILES_ACTIVE=prod
# JWT_SECRET=<your-256-char-secret>
# ADMIN_PASSWORD=<your-secure-password>
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
# REACT_APP_API_URL=https://api.yourdomain.com/api
